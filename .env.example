CERTBOT_EMAIL=you@example.com
TZ=Europe/Rome

DOMAIN_MAPPINGS="
# encrypted: Caddy terminates TLS and renew certificates automatically. 
# Upstream is always http:// to the third column.
encrypted secure.example.com api-service:80

# cleartext: Caddy does not handle TLS. TLS may have been terminated before caddy, or never have been started at all.
cleartext app.example.com docker-service-app:80

# optional 4th column: override Host sent upstream (virtual host / S3-style endpoints).
cleartext static.example.com minio:9000 static.example.com
"
